{
  "name": "mouse-trouble",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:buildmode": "vite --mode buildmode",
    "dev:live-glb": "npm run bake:house-glb && vite --mode live-glb",
    "dev:party": "node --env-file=.env ./node_modules/partykit/dist/bin.mjs dev",
    "prebuild": "npm run build:prepare",
    "build:prepare": "node scripts/generate-kitchen-layout-module.mjs && node scripts/generate-kitchen-navmesh-module.mjs && node scripts/generate-texture-atlas-registry.mjs",
    "build": "vite build",
    "build:full": "npm run assets:build && vite build",
    "assets:build": "node scripts/generate-kitchen-layout-module.mjs && node scripts/generate-kitchen-navmesh-module.mjs && node scripts/apply-mouse-skin.mjs && node scripts/generate-texture-atlas-registry.mjs && node scripts/analyze-texture-atlases.mjs && node scripts/optimize-runtime-images.mjs && node scripts/optimize-ambient-audio.mjs && node scripts/optimize-glb.mjs && node scripts/convert-cop-fbx.mjs && node scripts/convert-brain-fbx.mjs && node scripts/convert-jerry-fbx.mjs && node scripts/convert-gus-fbx.mjs && node scripts/convert-speedy-fbx.mjs && node scripts/bake-vegetation-trees.mjs && node scripts/bake-house-glb.mjs && node scripts/optimize-custom-glbs.mjs",
    "deploy:cf": "npm run build && wrangler deploy",
    "deploy:party": "node --env-file=.env.production ./node_modules/partykit/dist/bin.mjs deploy",
    "deploy": "npm run deploy:cf && npm run deploy:party",
    "dev:wavedash": "npm run build && wavedash dev",
    "deploy:wavedash": "npm run build && wavedash build push",
    "mouse:skin": "node scripts/apply-mouse-skin.mjs",
    "textures:analyze": "node scripts/analyze-texture-atlases.mjs",
    "preview": "vite preview",
    "dev:trim-audio": "node scripts/trim-audio-silence.mjs",
    "bench:net": "node scripts/bench-network.mjs",
    "bench:compare": "node scripts/bench-compare.mjs bench/baseline.json bench-results.json",
    "bots:live": "node scripts/live-bots.mjs",
    "bake:procedural-glbs": "node scripts/bake-vegetation-trees.mjs && node scripts/bake-house-glb.mjs",
    "bake:house-glb": "node scripts/bake-house-glb.mjs"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "cannon-es": "^0.20.0",
    "fflate": "^0.8.2",
    "mathcat": "^0.0.11",
    "navcat": "^0.3.0",
    "nipplejs": "^1.0.1",
    "obscenity": "^0.4.6",
    "partysocket": "^1.1.18",
    "solid-js": "^1.9.12",
    "three": "^0.184.0",
    "three-mesh-bvh": "^0.9.9"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "meshoptimizer": "^1.1.0",
    "partykit": "^0.0.115",
    "sharp": "^0.34.5",
    "vite": "8.0.5",
    "vite-plugin-solid": "^2.11.12",
    "wrangler": "^4.85.0",
    "ws": "^8.20.0"
  }
}
