# Copy to `.env` in the repo root (or run the same keys in PartyKit dashboard for deploy).
# `npm run dev` (Vite) loads this automatically. `npm run dev:party` loads `.env` via --env-file.

STATS_ADMIN_TOKEN=replace-with-openssl-rand-hex-48
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEV_LAYOUT_SYNC_ENABLED=true
DEV_LAYOUT_SYNC_TOKEN=replace-with-long-random-string
VITE_DEV_LAYOUT_SYNC_TOKEN=replace-with-same-as-DEV_LAYOUT_SYNC_TOKEN
VITE_PARTYKIT_HOST=localhost:1999
BENCH_METRICS_TOKEN=replace-with-random-string-for-npm-run-bench-net

# Cloudflare Turnstile (proof-of-humanity on WS connect). Leave unset in dev to
# disable. In prod: create a Turnstile site at https://dash.cloudflare.com/?to=/:account/turnstile
# set VITE_TURNSTILE_SITE_KEY (public, baked into client) and TURNSTILE_SECRET
# (private, PartyKit env only — `npx partykit env add TURNSTILE_SECRET`).
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=
# Allows non-browser WS clients (node `ws`, bench scripts) that send no Origin
# header. Enabled here for `npm run bench:net` against local dev. MUST be unset
# or "false" in the deployed PartyKit env.
ALLOW_EMPTY_ORIGIN=true
